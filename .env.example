CALCULATOR_LOG_DIR=logs
CALCULATOR_HISTORY_DIR=history
CALCULATOR_LOG_FILE=calculator.log
CALCULATOR_LOG_LEVEL=INFO
CALCULATOR_HISTORY_FILE=history.csv
CALCULATOR_MAX_HISTORY_SIZE=100
CALCULATOR_AUTO_SAVE=true
CALCULATOR_PRECISION=10
CALCULATOR_MAX_INPUT_VALUE=1000000
CALCULATOR_DEFAULT_ENCODING=utf-8
CALCULATOR_REPL_PROMPT=calc> 
CALCULATOR_REPL_WELCOME_MESSAGE=Calculator REPL started. Type 'help' for available commands.
CALCULATOR_REPL_USE_COLOR=true
